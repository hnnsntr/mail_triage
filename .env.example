# Database — provide your own PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/ai_mailing?schema=public"

# OpenAI — required for AI email analysis
OPENAI_API_KEY=""

# Encryption key for mail credentials at rest (must decode to 32 bytes)
# Generate one with: openssl rand -base64 32
ENCRYPTION_KEY=""

# Mail sync interval in seconds (default: 180)
SYNC_INTERVAL_SECONDS="180"

# Max emails to pull on first sync (default: 50)
INITIAL_SYNC_LIMIT="50"

# Set to true to auto-start background mail polling
# MAIL_SYNC_AUTOSTART="false"
